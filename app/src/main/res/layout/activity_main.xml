<?xml version="1.0" encoding="utf-8"?>

<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    tools:context=".MainActivity">

    <data>
        <variable
            name="sensor"
            type="com.example.smartirr.SensorData"/>
    </data>

<FrameLayout
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:adjustViewBounds="true"
        android:scaleType="centerCrop"
        android:src="@drawable/agriculture_field" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Smart Irrigation — Live"
                android:textSize="22sp"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:paddingBottom="10dp" />

            <!-- Temperature card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:src="@drawable/ic_thermometer"
                        android:contentDescription="temp icon"
                        android:padding="8dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingStart="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Temperature"
                            android:textStyle="bold"
                            android:textSize="16sp" />

                        <TextView
                            android:id="@+id/tempValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@{sensor.tempDisplay}"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:paddingTop="6dp"/>
                    </LinearLayout>

                    <ImageView
                        android:id="@+id/tempChange"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        app:changeIcon="@{sensor.temp}"
                        app:previousValue="@{sensor.prevTemp}" />
<!--                    app:animateChange="true"-->
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Row: Humidity & Moisture -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginBottom="12dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp"
                    android:layout_marginEnd="8dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Humidity"
                            android:textStyle="bold" />

                        <LinearLayout android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView android:id="@+id/humidityValue"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@{sensor.humidityDisplay}"
                                android:textSize="20sp"
                                android:paddingTop="6dp"/>

                            <ImageView
                                android:id="@+id/humidityChange"
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                app:changeIcon="@{sensor.humidity}"
                                app:previousValue="@{sensor.prevHumidity}" />
<!--                            app:animateChange="true"-->
                        </LinearLayout>

                        <ProgressBar
                            android:layout_width="match_parent"
                            android:layout_height="8dp"
                            android:layout_marginTop="8dp"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:progress="@{sensor.humidityPercent}" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp"
                    android:layout_marginStart="8dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Soil Moisture"
                            android:textStyle="bold" />

                        <LinearLayout android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView android:id="@+id/moistureValue"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@{sensor.moistureDisplay}"
                                android:textSize="20sp"
                                android:paddingTop="6dp"/>

                            <ImageView
                                android:id="@+id/moistureChange"
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                app:changeIcon="@{sensor.moisture}"
                                app:previousValue="@{sensor.prevMoisture}" />
<!--                            app:animateChange="true"-->
                        </LinearLayout>

                        <ProgressBar
                            android:layout_width="match_parent"
                            android:layout_height="8dp"
                            android:layout_marginTop="8dp"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:progress="@{sensor.moisturePercent}" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- Water level card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:src="@drawable/ic_water_drop" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingStart="12dp">

                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Water Level" android:textStyle="bold"/>

                        <TextView android:id="@+id/waterLevelValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@{sensor.waterLevelDisplay}"
                            android:textSize="22sp"
                            android:paddingTop="6dp"/>
                    </LinearLayout>

                    <ImageView
                        android:id="@+id/waterChange"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        app:changeIcon="@{sensor.waterLevel}"
                        app:previousValue="@{sensor.prevWaterLevel}"
                        />
<!--                    app:animateChange="true"-->
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/statusText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Status: waiting for data"
                android:textColor="@android:color/white"
                android:layout_marginTop="6dp"/>

        </LinearLayout>
    </ScrollView>

</FrameLayout>
</layout>